# Database Configuration
# For production on Vercel, use PostgreSQL (recommended) or MySQL
# SQLite is NOT supported on Vercel as it requires a filesystem

# Option 1: PostgreSQL (Recommended for Vercel)
# Get this from your Vercel Postgres database or external PostgreSQL provider
DATABASE_URL="postgresql://username:password@hostname:port/database_name?schema=public"

# Option 2: MySQL
# DATABASE_URL="mysql://username:password@hostname:port/database_name"

# Option 3: SQLite (ONLY for local development - NOT for Vercel)
# DATABASE_URL="file:./dev.db"

# Admin Credentials
ADMIN_EMAIL="chocolateshopee@gmail.com"
ADMIN_PASSWORD="CS@123"

# NextAuth Configuration (if needed)
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Vercel Postgres (if using Vercel's managed Postgres)
# POSTGRES_URL=""
# POSTGRES_PRISMA_URL=""
# POSTGRES_URL_NON_POOLING=""